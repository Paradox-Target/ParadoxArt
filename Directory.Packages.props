    <PackageVersion Include="BCnEncoder.Net.ImageSharp" Version="1.1.2" />
    <PackageVersion Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageVersion Include="DeviceId.Linux" Version="6.9.0" />
    <PackageVersion Include="DeviceId.Windows" Version="6.9.0" />
    <PackageVersion Include="FluentAvaloniaUI" Version="2.4.1" />
    <PackageVersion Include="JetBrains.Annotations" Version="2025.2.4" />
    <PackageVersion Include="MessageBox.Avalonia" Version="3.3.1" />
    <PackageVersion Include="NLog" Version="6.0.7" />
    <PackageVersion Include="ObservableCollections" Version="3.3.4" />
