<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">

    <Style x:Key="SettingsIconImageStyle" TargetType="Image">
        <Setter Property="Height" Value="200" />
        <Setter Property="Width" Value="200" />
    </Style>
    <Style x:Key="SettingsTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="Margin" Value="8,4" />
    </Style>
    <Style
        x:Key="SettingsPathTextBoxStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultTextBoxStyleKey}}"
        TargetType="TextBox">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="Margin" Value="8,0" />
    </Style>
    <Style
        x:Key="SettingsPickButtonStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultButtonStyleKey}}"
        TargetType="Button">
        <Setter Property="FontSize" Value="25" />
        <Setter Property="Margin" Value="8,0" />
        <Setter Property="Width" Value="50" />
    </Style>
    <Style
        x:Key="SettingsStepButtonStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultButtonStyleKey}}"
        TargetType="Button">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Margin" Value="8,0" />
        <Setter Property="Width" Value="150" />
    </Style>
    <Style
        x:Key="SettingsPickComboboxStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultComboBoxStyleKey}}"
        TargetType="ComboBox">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Margin" Value="8,0" />
    </Style>
</ResourceDictionary>