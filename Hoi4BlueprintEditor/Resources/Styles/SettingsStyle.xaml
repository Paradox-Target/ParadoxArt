<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <system:Double x:Key="Settings.TitleFontSize">35</system:Double>
    <system:Double x:Key="Settings.ContentFontSize">25</system:Double>

    <Style TargetType="Image" x:Key="Settings.IconImageStyle">
        <Setter Property="Height" Value="200" />
        <Setter Property="Width" Value="200" />
    </Style>
    <Style TargetType="TextBlock" x:Key="Settings.TitleTextBlockStyle">
        <Setter Property="FontSize" Value="{StaticResource Settings.TitleFontSize}" />
        <Setter Property="Margin" Value="10,5" />
    </Style>
    <Style TargetType="TextBox" x:Key="Settings.PathTextBoxStyle">
        <Setter Property="FontSize" Value="{StaticResource Settings.ContentFontSize}" />
        <Setter Property="Margin" Value="10,0" />
    </Style>
    <Style TargetType="Button" x:Key="Settings.PickButtonStyle">
        <Setter Property="FontSize" Value="{StaticResource Settings.ContentFontSize}" />
        <Setter Property="Margin" Value="10,0" />
        <Setter Property="Width" Value="50" />
    </Style>
    <Style TargetType="Button" x:Key="Settings.StepButtonStyle">
        <Setter Property="FontSize" Value="{StaticResource Settings.ContentFontSize}" />
        <Setter Property="Margin" Value="10,0" />
        <Setter Property="Width" Value="150" />
    </Style>
    <Style TargetType="ComboBox" x:Key="Settings.PickComboboxStyle">
        <Setter Property="FontSize" Value="{StaticResource Settings.ContentFontSize}" />
        <Setter Property="Margin" Value="10,0" />
    </Style>
</ResourceDictionary>