<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">
    <Style BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultTextBoxStyleKey}}" TargetType="TextBox">
        <Setter Property="FontFamily" Value="Cascadia Code" />
    </Style>

    <FontFamily x:Key="ContentControlThemeFontFamily">Sarasa UI SC</FontFamily>

    <Style TargetType="ui:NumberBox">
        <Setter Property="FontFamily" Value="Cascadia Code" />
    </Style>

    <Style BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultComboBoxStyleKey}}" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Cascadia Code" />
    </Style>

    <Style BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultMenuStyleKey}}" TargetType="Menu">
        <Setter Property="FontFamily" Value="Sarasa UI SC" />
    </Style>

    <Style BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultButtonStyleKey}}" TargetType="Button">
        <Setter Property="FontFamily" Value="Sarasa UI SC" />
    </Style>
</ResourceDictionary>