<UserControl
    d:DataContext="{d:DesignInstance vms:FocusNodeViewModel}"
    d:DesignHeight="70"
    d:DesignWidth="50"
    mc:Ignorable="d"
    x:Class="Hoi4BlueprintEditor.Views.FocusNodeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        Background="#555"
        Height="{StaticResource FocusNodeHeight}"
        ToolTip="{Binding Model.Id}"
        Width="{StaticResource FocusNodeWidth}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Image
            Grid.Row="0"
            Height="{Binding Height}"
            Source="{Binding BitmapSource}"
            Width="{Binding Width}" />

        <TextBlock
            FontSize="12"
            Foreground="White"
            Grid.Row="1"
            HorizontalAlignment="Center"
            Margin="2,0"
            Text="{Binding LocalizedName}"
            TextTrimming="CharacterEllipsis"
            VerticalAlignment="Center" />
    </Grid>
</UserControl>
