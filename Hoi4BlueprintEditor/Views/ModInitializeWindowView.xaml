<Window
    x:Class="Hoi4BlueprintEditor.Views.ModInitializeWindowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:language="clr-namespace:Hoi4BlueprintEditor.Resources.Strings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    Title="ModInitializeWindowView"
    Width="800"
    Height="450"
    d:DataContext="{d:DesignInstance vms:ModInitializeWindowViewModel}"
    Visibility="{Binding Visible}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  <Button  -->
        <!--  Command="{Binding CreateModCommand}"  -->
        <!--  Content="{x:Static language:Strings.ModIni_CreateMod}"  -->
        <!--  Grid.Column="0"  -->
        <!--  HorizontalAlignment="Center" />  -->
        <Button
            Grid.Column="1"
            HorizontalAlignment="Center"
            Command="{Binding OpenModCommand}"
            Content="{x:Static language:Strings.ModIni_OpenMod}" />
        <ListView
            Grid.Column="2"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center">
            <ListViewItem Content="文件树" />
        </ListView>
    </Grid>
</Window>
