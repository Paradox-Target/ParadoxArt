<UserControl
    x:Class="Hoi4BlueprintEditor.Views.EditorCanvasView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Hoi4BlueprintEditor.Controls"
    xmlns:converters="clr-namespace:Hoi4BlueprintEditor.Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:views="clr-namespace:Hoi4BlueprintEditor.Views"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    d:DataContext="{d:DesignInstance vms:EditorCanvasViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    Background="#333333"
    Unloaded="EditorCanvasView_OnUnloaded"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:CoordinateToPixelConverter x:Key="CoordinateToPixelConverter" />

    </UserControl.Resources>

    <Grid ClipToBounds="True">

        <controls:GridRulerControl
            Scale="{Binding Scale}"
            TranslateX="{Binding TranslateX}"
            TranslateY="{Binding TranslateY}" />

        <ItemsControl ItemsSource="{Binding Nodes}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <views:FocusNodeView />
                </DataTemplate>
            </ItemsControl.ItemTemplate>

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas RenderTransformOrigin="0.5,0.5">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                                <TranslateTransform X="{Binding TranslateX}" Y="{Binding TranslateY}" />
                            </TransformGroup>
                        </Canvas.RenderTransform>
                    </Canvas>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Model.X, Converter={StaticResource CoordinateToPixelConverter}, ConverterParameter=96}" />
                    <Setter Property="Canvas.Top" Value="{Binding Model.Y, Converter={StaticResource CoordinateToPixelConverter}, ConverterParameter=130}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
        </ItemsControl>

        <Popup
            x:Name="FocusInfoView"
            d:DataContext="{d:DesignInstance vms:FocusInfoViewModel}"
            AllowsTransparency="True"
            MouseLeftButtonDown="FocusInfoView_OnMouseLeftButtonDown"
            Placement="Custom"
            StaysOpen="True">
            <Border
                MinWidth="200"
                Padding="10"
                Background="AliceBlue"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBox ui:ControlHelper.Header="ID" Text="{Binding Id, Mode=TwoWay}" />

                    <ui:NumberBox
                        Header="Cost"
                        Minimum="0"
                        SpinButtonPlacementMode="Inline"
                        ValidationMode="InvalidInputOverwritten"
                        Value="{Binding Cost, Mode=TwoWay}" />


                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
