<UserControl
    Background="#333333"
    d:DataContext="{d:DesignInstance vms:EditorCanvasViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    mc:Ignorable="d"
    x:Class="Hoi4BlueprintEditor.Views.EditorCanvasView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:controls="clr-namespace:Hoi4BlueprintEditor.Controls"
    xmlns:converters="clr-namespace:Hoi4BlueprintEditor.Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Hoi4BlueprintEditor.Views"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <converters:CoordinateToPixelConverter x:Key="CoordinateToPixelConverter" />

    </UserControl.Resources>

    <Grid ClipToBounds="True">

        <controls:GridRulerControl
            Grid.ZIndex="1"
            Scale="{Binding Scale}"
            TranslateX="{Binding TranslateX}"
            TranslateY="{Binding TranslateY}" />

        <controls:FocusMapControl
            Grid.ZIndex="0"
            ItemsSource="{Binding Nodes}"
            ScaleX="{Binding Scale}"
            ScaleY="{Binding Scale}"
            TranslateX="{Binding TranslateX}"
            TranslateY="{Binding TranslateY}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <views:FocusNodeView />
                </DataTemplate>
            </ItemsControl.ItemTemplate>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Model.X, Converter={StaticResource CoordinateToPixelConverter}, ConverterParameter={StaticResource FocusNodeWidth}}" />
                    <Setter Property="Canvas.Top" Value="{Binding Model.Y, Converter={StaticResource CoordinateToPixelConverter}, ConverterParameter={StaticResource FocusNodeHeight}}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
        </controls:FocusMapControl>

        <views:FocusInfoView x:Name="FocusInfoView" />
    </Grid>
</UserControl>
