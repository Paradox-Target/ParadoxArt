<UserControl
    x:Class="Hoi4BlueprintEditor.Views.MainControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:language="clr-namespace:Hoi4BlueprintEditor.Resources.Strings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Hoi4BlueprintEditor.Views"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    d:DataContext="{d:DesignInstance vms:MainControlViewModel}"
    d:DesignHeight="{StaticResource MainWindowHeight}"
    d:DesignWidth="{StaticResource MainWindowWidth}"
    mc:Ignorable="d">
    <DockPanel LastChildFill="True">

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{x:Static language:Strings.FileMenu}">
                <MenuItem Header="{x:Static language:Strings.NewMenuItem}" />
                <MenuItem Command="{Binding OpenFocusFileCommand}" Header="{x:Static language:Strings.OpenMenuItem}" />
                <MenuItem Command="{Binding SaveFocusFileCommand}" Header="{x:Static language:Strings.SaveMenuItem}" />
                <Separator />
                <MenuItem Command="{Binding OpenModInitializePageViewCommand}" Header="模组初始化" />
                <Separator />
                <MenuItem Header="{x:Static language:Strings.ExitMenuItem}" />
            </MenuItem>
            <!-- <MenuItem Header="{x:Static language:Strings.EditMenuItem}"> -->
            <!--     <MenuItem Header="{x:Static language:Strings.UndoMenuItem}" /> -->
            <!--     <MenuItem Header="{x:Static language:Strings.RedoMenuItem}" /> -->
            <!-- </MenuItem> -->
            <MenuItem Command="{Binding SaveFocusTreeToPngCommand}" Header="导出国策树截图" />

            <MenuItem Header="{x:Static language:Strings.Menu_Settings}">
                <MenuItem Command="{Binding OpenSettingsViewCommand}" Header="配置项" />
                <MenuItem Header="{x:Static language:Strings.Menu_Language}">
                    <MenuItem Command="{Binding SetLanguageToChineseCommand}" Header="中文" />
                    <MenuItem Command="{Binding SetLanguageToEnglishCommand}" Header="English" />
                </MenuItem>
                <MenuItem Command="{Binding GameSettingsCommand}" Header="{x:Static language:Strings.Menu_GameSettings}" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="准备就绪" />
            </StatusBarItem>
        </StatusBar>

        <views:EditorCanvasView />

    </DockPanel>
</UserControl>
