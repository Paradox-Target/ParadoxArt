<Window
    Height="768"
    Title="{x:Static language:Strings.AppTitle}"
    Width="1024"
    WindowStartupLocation="CenterScreen"
    d:DataContext="{d:DesignInstance vms:MainViewModel}"
    mc:Ignorable="d"
    x:Class="Hoi4BlueprintEditor.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:language="clr-namespace:Hoi4BlueprintEditor.Resources.Strings"
    xmlns:local="clr-namespace:Hoi4BlueprintEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel LastChildFill="True">

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{x:Static language:Strings.FileMenu}">
                <MenuItem Header="{x:Static language:Strings.NewMenuItem}" />
                <MenuItem Header="{x:Static language:Strings.OpenMenuItem}" />
                <MenuItem Header="{x:Static language:Strings.SaveMenuItem}" />
                <Separator />
                <MenuItem Header="{x:Static language:Strings.ExitMenuItem}" />
            </MenuItem>
            <MenuItem Header="{x:Static language:Strings.EditMenuItem}">
                <MenuItem Header="{x:Static language:Strings.UndoMenuItem}" />
                <MenuItem Header="{x:Static language:Strings.RedoMenuItem}" />
            </MenuItem>
            <MenuItem Header="{x:Static language:Strings.ViewMenuItem}">
                <MenuItem Header="{x:Static language:Strings.ZInMenuItem}" />
                <MenuItem Header="{x:Static language:Strings.ZOutMenuItem}" />
            </MenuItem>
            <MenuItem Header="{x:Static language:Strings.HelpMenuItem}">
                <MenuItem Header="{x:Static language:Strings.AboutMenuItem}" />
            </MenuItem>
            <MenuItem Header="语言(Language)">
                <MenuItem Command="{Binding SetLanguageToChineseCommand}" Header="中文" />
                <MenuItem Command="{Binding SetLanguageToEnglishCommand}" Header="English" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="准备就绪" />
            </StatusBarItem>
        </StatusBar>

        <Grid Background="#333333">
            <TextBlock
                FontSize="24"
                Foreground="White"
                HorizontalAlignment="Center"
                Text="这里是国策树编辑区"
                VerticalAlignment="Center" />
        </Grid>

    </DockPanel>
</Window>