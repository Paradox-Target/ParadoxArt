<Window
    Height="768"
    Title="{x:Static language:Strings.AppTitle}"
    Width="1024"
    WindowStartupLocation="CenterScreen"
    d:DataContext="{d:DesignInstance vms:MainWindowViewModel}"
    mc:Ignorable="d"
    x:Class="Hoi4BlueprintEditor.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:language="clr-namespace:Hoi4BlueprintEditor.Resources.Strings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ContentControl Content="{Binding CurrentView}" />
</Window>