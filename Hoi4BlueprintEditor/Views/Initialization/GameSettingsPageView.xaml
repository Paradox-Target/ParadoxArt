<Page
    Title="GameSettingsPageView"
    d:DataContext="{d:DesignInstance vms:GameSettingsPageViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="500"
    mc:Ignorable="d"
    x:Class="Hoi4BlueprintEditor.Views.Initialization.GameSettingsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
    xmlns:language="clr-namespace:Hoi4BlueprintEditor.Resources.Strings"
    xmlns:local="clr-namespace:Hoi4BlueprintEditor.Views.Initialization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels.Initialization"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.RowSpan="2">
            <emoji:TextBlock
                FontFamily="{StaticResource Icon}"
                FontSize="200"
                HorizontalAlignment="Center"
                Text="&#x1f4c2;"
                VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel
            Grid.Column="1"
            Grid.Row="0"
            Margin="20">
            <StackPanel Margin="0,15">
                <TextBlock
                    FontSize="{StaticResource TitleFontSize}"
                    Margin="8,4"
                    Text="{x:Static language:Strings.GameSettings_GameRoot}"
                    VerticalAlignment="Center" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Margin="0,0,10,0" Text="{Binding GamePath, Mode=OneWay}" />
                    <Button
                        Command="{Binding PickGamePathCommand}"
                        Content="{x:Static language:Strings.GameSettings_Overview}"
                        Grid.Column="1" />
                </Grid>
            </StackPanel>

            <StackPanel Margin="0,15">
                <TextBlock
                    FontSize="{StaticResource TitleFontSize}"
                    Margin="8,4"
                    Text="{x:Static language:Strings.GameSettings_ModRoot}"
                    VerticalAlignment="Center" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Margin="0,0,10,0" Text="{Binding ModPath, Mode=TwoWay}" />
                    <Button
                        Command="{Binding PickModPathCommand}"
                        Content="{x:Static language:Strings.GameSettings_Overview}"
                        Grid.Column="1" />
                </Grid>
            </StackPanel>

            <DockPanel Margin="15,30">
                <Button
                    Command="{Binding GoToNextPageCommand, Mode=Default}"
                    Content="下一步"
                    HorizontalAlignment="Right" />
            </DockPanel>
        </StackPanel>
    </Grid>
</Page>
