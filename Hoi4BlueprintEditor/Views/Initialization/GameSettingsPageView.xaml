<Page
    x:Class="Hoi4BlueprintEditor.Views.Initialization.GameSettingsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Hoi4BlueprintEditor.Views.Initialization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels.Initialization"
    Title="GameSettingsPageView"
    d:DataContext="{d:DesignInstance vms:GameSettingsPageViewModel}"
    d:DesignHeight="{StaticResource MainWindowHeight}"
    d:DesignWidth="{StaticResource MainWindowWidth}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <DockPanel>
                <TextBlock
                    Margin="8,4"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    Text="游戏根目录: " />
                <TextBox VerticalAlignment="Top" Text="{Binding GamePath, Mode=OneWay}" />
                <Button
                    Margin="8,4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding PickGamePathCommand}"
                    Content="选择文件夹"
                    DockPanel.Dock="Right" />
            </DockPanel>

            <DockPanel>
                <TextBlock
                    Margin="8,4"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    Text="Mod 根目录: " />
                <TextBox Text="{Binding ModPath, Mode=TwoWay}" />
                <Button
                    Margin="8,4"
                    HorizontalAlignment="Right"
                    Command="{Binding PickModPathCommand}"
                    Content="选择文件夹"
                    DockPanel.Dock="Right" />
            </DockPanel>
        </StackPanel>


        <StackPanel Grid.Row="1">
            <Button
                Margin="0,0,24,24"
                HorizontalAlignment="Right"
                Command="{Binding GoToNextPageCommand, Mode=Default}"
                Content="下一步" />
        </StackPanel>
    </Grid>
</Page>
