<UserControl
    x:Class="Hoi4BlueprintEditor.Views.FocusInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewsModels="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    HorizontalAlignment="Right"
    VerticalAlignment="Center"
    d:DataContext="{d:DesignInstance viewsModels:FocusInfoViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Visibility="Collapsed"
    mc:Ignorable="d">

    <Grid>

        <ui:AcrylicPanel
            Margin="0"
            Amount="80"
            Background="{DynamicResource {x:Static ui:ThemeKeys.SolidBackgroundFillColorBaseBrushKey}}"
            CornerRadius="5"
            Target="{Binding ElementName=InfoBorder}"
            TintColor="Snow"
            TintOpacity="0.6" />

        <Border
            x:Name="InfoBorder"
            MinWidth="200"
            Padding="10"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    AllowDrop="True"
                    Drop="FocusIcon_OnDrop">
                    <TextBlock FontFamily="Sarasa UI SC" Text="Icon" />
                    <Image
                        x:Name="FocusIcon"
                        Margin="0,0,0,8"
                        ToolTip="{Binding IconPath}" />
                    <TextBox FontFamily="Cascadia Code" Text="{Binding FocusNode.Icon, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="Sarasa UI SC"
                        Text="ID" />

                    <TextBox
                        Margin="0,4,0,0"
                        FontFamily="Cascadia Code"
                        Text="{Binding FocusNode.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="定位系统: " />
                    <Border Background="#71afe5" CornerRadius="4">
                        <TextBlock Margin="4" Text="{Binding LocationSystemText, Mode=OneWay}" />
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Row="3"
                    Margin="0,8,0,0"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="Sarasa UI SC"
                        Text="X: " />
                    <ui:NumberBox FontFamily="Cascadia Code" Value="{Binding X, Mode=TwoWay}" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontFamily="Sarasa UI SC"
                        Text="Y: " />
                    <ui:NumberBox FontFamily="Cascadia Code" Value="{Binding Y, Mode=TwoWay}" />
                </StackPanel>

                <TextBlock
                    Grid.Row="4"
                    Margin="0,8,0,0"
                    FontFamily="Sarasa UI SC"
                    Text="Cost" />

                <StackPanel
                    Grid.Row="5"
                    Margin="0,4,0,0"
                    Orientation="Horizontal">
                    <ui:NumberBox
                        FontFamily="Cascadia Code"
                        Minimum="0"
                        SpinButtonPlacementMode="Inline"
                        ValidationMode="InvalidInputOverwritten"
                        Value="{Binding Cost, Mode=TwoWay}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="Sarasa UI SC"
                        FontSize="18"
                        Text="{Binding FocusDaysTip}" />
                </StackPanel>

                <StackPanel
                    Grid.Row="6"
                    Margin="0,8,0,0"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="Sarasa UI SC"
                        FontSize="22"
                        Text="本地化" />
                    <ComboBox
                        Margin="8,0,0,0"
                        FontFamily="Cascadia Code"
                        ItemsSource="{Binding Languages, Mode=OneTime}"
                        SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Row="7">
                    <TextBlock
                        Margin="0,4,0,0"
                        FontFamily="Sarasa UI SC"
                        Text="Text" />

                    <TextBox
                        Margin="0,4,0,0"
                        FontFamily="Cascadia Code"
                        Text="{Binding IdText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                </StackPanel>

                <StackPanel Grid.Row="8">
                    <TextBlock
                        Margin="0,4,0,0"
                        FontFamily="Sarasa UI SC"
                        Text="描述" />

                    <TextBox
                        Margin="0,8,0,0"
                        VerticalAlignment="Top"
                        AcceptsReturn="True"
                        FontFamily="Cascadia Code, Sarasa UI SC"
                        Text="{Binding DescriptionText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                        TextWrapping="WrapWithOverflow"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>