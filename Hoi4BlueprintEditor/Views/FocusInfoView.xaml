<UserControl
    x:Class="Hoi4BlueprintEditor.Views.FocusInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewsModels="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    HorizontalAlignment="Right"
    VerticalAlignment="Center"
    d:DataContext="{d:DesignInstance viewsModels:FocusInfoViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Visibility="Collapsed"
    mc:Ignorable="d">

    <Border
        MinWidth="200"
        Padding="10"
        Background="AliceBlue"
        BorderBrush="Gray"
        BorderThickness="1"
        CornerRadius="4">
        <StackPanel>
            <StackPanel AllowDrop="True" Drop="FocusIcon_OnDrop">
                <TextBlock Text="Icon" />
                <Image
                    x:Name="FocusIcon"
                    Margin="0,0,0,8"
                    ToolTip="{Binding IconPath}" />
            </StackPanel>
            <TextBox ui:ControlHelper.Header="ID" Text="{Binding FocusNode.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Orientation="Horizontal">
                <ui:NumberBox
                    Header="Cost"
                    Minimum="0"
                    SpinButtonPlacementMode="Inline"
                    ValidationMode="InvalidInputOverwritten"
                    Value="{Binding Cost, Mode=TwoWay}" />
                <TextBlock
                    VerticalAlignment="Bottom"
                    FontSize="20"
                    Text="{Binding FocusDaysTip}" />
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>
