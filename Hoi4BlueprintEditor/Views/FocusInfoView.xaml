<UserControl
    x:Class="Hoi4BlueprintEditor.Views.FocusInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewsModels="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    HorizontalAlignment="Right"
    VerticalAlignment="Center"
    d:DataContext="{d:DesignInstance viewsModels:FocusInfoViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Visibility="Collapsed"
    mc:Ignorable="d">

    <!-- 详细计划（伪代码）:
         目标：当右侧垂直滚动条出现时，仅增加右侧内边距，避免滚动条遮挡 InfoBorder 内部元素；默认为统一 10 的内边距。

         步骤:
         1. 保持现有 ScrollViewer 的属性（VerticalScrollBarVisibility="Auto"、默认 Padding="10"）。
         2. 在 ScrollViewer 内添加一个 Style：
            - 默认 Setter 将 Padding 设为 "10"（即四边均为 10）。
            - 添加 Trigger，监听 ScrollViewer 的 ComputedVerticalScrollBarVisibility 属性。
            - 当该属性等于 Visible 时，使用 Setter 将 Padding 改为 "10,10,17,10"（左,上,右,下），右侧增加典型滚动条宽度 17。
         3. 只在滚动条出现时改变右侧间距；其他情况保留默认 Padding。
         4. 保持对现有内容布局和主题的其余配置不变。
    -->

    <UserControl.Resources>
        <!-- 调整行号与代码区域/右侧分隔线的距离 -->
        <Style TargetType="{x:Type avalonEdit:LineNumberMargin}">
            <!-- 右侧间距：越大表示行号与代码之间的空隙越大 -->
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
    </UserControl.Resources>

    <Grid>

        <ui:AcrylicPanel
            Margin="0"
            Amount="80"
            Background="{DynamicResource {x:Static ui:ThemeKeys.SolidBackgroundFillColorBaseBrushKey}}"
            CornerRadius="5"
            Target="{Binding ElementName=InfoBorder}"
            TintColor="Snow"
            TintOpacity="0.6" />

        <Border
            x:Name="InfoBorder"
            MinWidth="200"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="4">
            <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <!-- 默认内边距：四边均为 10 -->
                        <Setter Property="Padding" Value="10" />
                        <Style.Triggers>
                            <!-- 当垂直滚动条出现时，仅增加右边内边距，避免遮挡内容 -->
                            <Trigger Property="ComputedVerticalScrollBarVisibility" Value="Visible">
                                <Setter Property="Padding" Value="10,10,18,10" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        AllowDrop="True"
                        Drop="FocusIcon_OnDrop">
                        <TextBlock Text="Icon" />
                        <Image
                            x:Name="FocusIcon"
                            Margin="0,0,0,8"
                            ToolTip="{Binding IconPath}" />
                        <TextBox Text="{Binding FocusNode.Icon, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Margin="0,8,0,0" Text="ID" />
                        <TextBox Margin="0,4,0,0" Text="{Binding FocusNode.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="定位系统: " />
                        <Border Background="#71afe5" CornerRadius="4">
                            <TextBlock Margin="4" Text="{Binding LocationSystemText, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Grid.Row="3"
                        Margin="0,8,0,0"
                        Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="X: " />
                        <ui:NumberBox Value="{Binding X, Mode=TwoWay}" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="Y: " />
                        <ui:NumberBox Value="{Binding Y, Mode=TwoWay}" />
                    </StackPanel>

                    <TextBlock
                        Grid.Row="4"
                        Margin="0,8,0,0"
                        Text="Cost" />

                    <StackPanel
                        Grid.Row="5"
                        Margin="0,4,0,0"
                        Orientation="Horizontal">
                        <ui:NumberBox
                            Minimum="0"
                            SpinButtonPlacementMode="Inline"
                            ValidationMode="InvalidInputOverwritten"
                            Value="{Binding Cost, Mode=TwoWay}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            Text="{Binding FocusDaysTip}" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Margin="0,8,0,0">
                        <TextBlock FontSize="22" Text="完成效果" />
                        <!-- 将包裹编辑器的边框改为仅底部一条灰色边线，像原生输入框一样 -->
                        <Border
                            Margin="0,4,0,0"
                            CornerRadius="4"
                            BorderBrush="Gray"
                            BorderThickness="0,0,0,1"
                            Background="{DynamicResource {x:Static ui:ThemeKeys.SolidBackgroundFillColorBaseBrushKey}}">
                            <avalonEdit:TextEditor
                                Name="CompletionRewardEditor"
                                FontFamily="Cascadia Code"
                                FontSize="12pt"
                                ShowLineNumbers="True"
                                Padding="4,0,0,18"
                                Background="Transparent"/>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Grid.Row="7"
                        Margin="0,8,0,0"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="22"
                            Text="本地化" />
                        <ComboBox
                            Margin="8,0,0,0"
                            ItemsSource="{Binding Languages, Mode=OneTime}"
                            SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="8">
                        <TextBlock Margin="0,4,0,0" Text="Text" />
                        <TextBox Margin="0,4,0,0" Text="{Binding IdText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>

                    <StackPanel Grid.Row="9">
                        <TextBlock Margin="0,4,0,0" Text="描述" />

                        <TextBox
                            Margin="0,8,0,0"
                            VerticalAlignment="Top"
                            AcceptsReturn="True"
                            FontFamily="Cascadia Code, Sarasa UI SC"
                            Text="{Binding DescriptionText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                            TextWrapping="WrapWithOverflow"
                            VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>