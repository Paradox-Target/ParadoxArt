<UserControl
    x:Class="Hoi4BlueprintEditor.Views.Dialogs.CreateNewFocusTreeFileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels.Dialogs"
    d:DataContext="{d:DesignInstance vms:CreateNewFocusTreeFileViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBox
            Grid.Row="0"
            MinWidth="200"
            Margin="8,0"
            VerticalAlignment="Center"
            ui:ControlHelper.Header="文件名"
            Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBox
            Grid.Row="1"
            MinWidth="200"
            Margin="8,0"
            VerticalAlignment="Center"
            ui:ControlHelper.Header="Id"
            Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBox
            Grid.Row="2"
            MinWidth="200"
            Margin="8,0"
            VerticalAlignment="Center"
            ui:ControlHelper.Header="国家 Tag"
            Text="{Binding CountryTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <ui:ToggleSwitch
            Grid.Row="3"
            Margin="8,8,8,0"
            Header="是默认国策树"
            IsOn="{Binding IsDefaultFocusTree, Mode=TwoWay}" />
    </Grid>
</UserControl>
