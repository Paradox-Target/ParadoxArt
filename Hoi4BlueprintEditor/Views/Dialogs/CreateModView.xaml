<UserControl
    d:DataContext="{d:DesignInstance vms:CreateModViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="Hoi4BlueprintEditor.Views.Dialogs.CreateModView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Hoi4BlueprintEditor.Views.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels.Dialogs"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBox
            Grid.Row="0"
            Margin="4"
            Text="{Binding ModName, Mode=TwoWay}"
            VerticalAlignment="Center"
            ui:ControlHelper.Header="Mod名称" />

        <Grid Grid.Column="0" Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                Margin="4"
                Text="{Binding RootFolder, Mode=TwoWay}"
                VerticalAlignment="Center"
                ui:ControlHelper.Header="Mod文件夹" />
            <Button
                Command="{Binding SelectRootFolderCommand}"
                Content="浏览文件夹"
                Grid.Column="1"
                VerticalAlignment="Bottom" />
        </Grid>

        <TextBox
            Grid.Row="2"
            Margin="4"
            Text="{Binding Version, Mode=TwoWay}"
            VerticalAlignment="Center"
            ui:ControlHelper.Header="推荐游戏版本" />
    </Grid>
</UserControl>
