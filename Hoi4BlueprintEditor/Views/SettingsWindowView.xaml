<Window
    x:Class="Hoi4BlueprintEditor.Views.SettingsWindowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:lang="clr-namespace:Hoi4BlueprintEditor.Resources.Strings"
    xmlns:local="clr-namespace:Hoi4BlueprintEditor.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:root="clr-namespace:Hoi4BlueprintEditor"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vms="clr-namespace:Hoi4BlueprintEditor.ViewsModels"
    Title="SettingsWindowView"
    Width="800"
    Height="450"
    d:DataContext="{d:DesignInstance vms:SettingsWindowViewModel}"
    ui:TitleBar.Height="36"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True"
    Closed="SettingsWindowView_OnClosed"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <ikw:SimpleStackPanel Margin="8,0" Spacing="4">
            <ui:SettingsCard Description="{Binding GameRootFolderPath, Mode=OneWay}" Header="{x:Static lang:Strings.GameSettings_GameRoot}">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xED25;" />
                </ui:SettingsCard.HeaderIcon>
                <Button Command="{Binding PickGameRootPathCommand}" Content="重新选择" />
            </ui:SettingsCard>

            <ui:SettingsCard Description="使用 DDS 格式有助于加快游戏载入速度" Header="导入 PNG 时自动转换成 DDS 格式">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE89E;" />
                </ui:SettingsCard.HeaderIcon>
                <ui:ToggleSwitch
                    IsOn="{Binding IsAutoFocusPngConvertToDds, Mode=TwoWay}"
                    OffContent=""
                    OnContent="" />
            </ui:SettingsCard>

            <ui:SettingsCard Description="*重启App后生效" Header="App 语言">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xF2B7;" />
                </ui:SettingsCard.HeaderIcon>
                <ComboBox ItemsSource="{Binding AppLanguages, Mode=OneTime}" SelectedIndex="{Binding SelectedAppLanguagesIndex, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName, Mode=OneTime}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </ui:SettingsCard>

            <ui:SettingsCard Description="*重启App后生效" Header="游戏本地化语言">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xF2B7;" />
                </ui:SettingsCard.HeaderIcon>
                <ComboBox ItemsSource="{Binding GameLanguages, Mode=OneTime}" SelectedIndex="{Binding SelectedGameLanguagesIndex, Mode=TwoWay}" />
            </ui:SettingsCard>

            <ui:SettingsCard
                Click="OpenSettingsFolder"
                Description="{x:Static root:App.ConfigFolder}"
                Header="打开配置文件夹"
                IsClickEnabled="True">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE8DA;" />
                </ui:SettingsCard.HeaderIcon>
                <ui:SettingsCard.ActionIcon>
                    <ui:FontIcon Glyph="&#xE8A7;" />
                </ui:SettingsCard.ActionIcon>
            </ui:SettingsCard>

            <TextBlock 
                Margin="4,4,0,4"
                FontSize="18"
                FontWeight="Bold"
                Text="关于" />

            <ui:SettingsExpander 
                Description="© Editer Commitee 2025. All rights reserved."
                Header="Focus Editer">
                <ui:SettingsExpander.HeaderIcon>
                    <Image Source="/Resources/Icons/logo.png"
                        Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                </ui:SettingsExpander.HeaderIcon>
                <TextBlock Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                    Text="0.0.1" />
                <ui:SettingsExpander.Items>
                    <ui:SettingsCard HorizontalContentAlignment="Left"
                        ContentAlignment="Left">
                        <StackPanel Margin="-12,0,0,0"
                            Orientation="Vertical">
                            <ui:HyperlinkButton Content="反馈问题" />
                        </StackPanel>
                    </ui:SettingsCard>
                </ui:SettingsExpander.Items>
            </ui:SettingsExpander>

            <ui:SettingsExpander
                Margin="0,0,0,8"
                Header="开源项目使用情况">
                <ui:SettingsExpander.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE943;"/>
                </ui:SettingsExpander.HeaderIcon>
                <ui:SettingsExpander.Items>
                    <ui:SettingsCard HorizontalContentAlignment="Left"
                        ContentAlignment="Left">
                        <StackPanel Margin="-12,0,0,0"
                            Orientation="Vertical">
                            <ui:HyperlinkButton 
                                NavigateUri="https://github.com/be5invis/Sarasa-Gothic"
                                Content="Sarasa-Gothic" />
                            <ui:HyperlinkButton 
                                NavigateUri="https://github.com/microsoft/cascadia-code"
                                Content="cascadia-code" />
                            <ui:HyperlinkButton 
                                NavigateUri="https://github.com/iNKORE-NET/UI.WPF.Modern"
                                Content="UI.WPF.Modern" />
                        </StackPanel>
                    </ui:SettingsCard>
                </ui:SettingsExpander.Items>
            </ui:SettingsExpander>
        </ikw:SimpleStackPanel>
    </ScrollViewer>
    
  
</Window>
