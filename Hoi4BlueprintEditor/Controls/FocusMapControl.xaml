<ItemsControl
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="Hoi4BlueprintEditor.Controls.FocusMapControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="clr-namespace:Hoi4BlueprintEditor.Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Hoi4BlueprintEditor.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Hoi4BlueprintEditor.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
            <Canvas RenderTransformOrigin="0,0" x:Name="PartCanvas">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                        <TranslateTransform X="{Binding TranslateX}" Y="{Binding TranslateY}" />
                    </TransformGroup>
                </Canvas.RenderTransform>
            </Canvas>
        </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>

</ItemsControl>
