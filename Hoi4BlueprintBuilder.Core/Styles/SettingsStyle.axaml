<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Image.SettingsIconImage">
        <Setter Property="Height" Value="200" />
        <Setter Property="Width" Value="200" />
    </Style>
    <Style Selector="TextBlock.SettingsTitleTextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="Margin" Value="8,4" />
    </Style>
    <Style Selector="TextBox.SettingsPathTextBox">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="Margin" Value="8,0" />
    </Style>
    <Style Selector="Button.SettingsPickButton">
        <Setter Property="FontSize" Value="25" />
        <Setter Property="Margin" Value="8,0" />
        <Setter Property="Width" Value="50" />
    </Style>
    <Style Selector="Button.SettingsStepButton">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Margin" Value="8,0" />
        <Setter Property="Width" Value="150" />
    </Style>
    <Style Selector="ComboBox.SettingsPickComboboxStyle">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Margin" Value="8,0" />
    </Style>
</Styles>