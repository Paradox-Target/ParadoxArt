<Application
    x:Class="Hoi4BlueprintBuilder.Core.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:Hoi4BlueprintBuilder.Core"
    xmlns:local="using:Hoi4BlueprintBuilder"
    xmlns:styling="clr-namespace:FluentAvalonia.Styling;assembly=FluentAvalonia"
    RequestedThemeVariant="Default">
    <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->

    <Application.Styles>
        <styling:FluentAvaloniaTheme />
        <StyleInclude Source="/Styles/DefaultStyles.axaml" />
        <StyleInclude Source="/Styles/SettingsStyle.axaml" />
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Assets/ConstantDictionary.axaml" />
                <ResourceInclude Source="/Assets/Icons/IconsDictionary.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>