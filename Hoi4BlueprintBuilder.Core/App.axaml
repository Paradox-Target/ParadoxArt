<Application
    x:Class="Hoi4BlueprintBuilder.Core.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:Hoi4BlueprintBuilder.Core"
    xmlns:local="using:Hoi4BlueprintBuilder"
    RequestedThemeVariant="Default">
    <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Styles/DefaultStyles.axaml" />
        <StyleInclude Source="/Styles/SettingsStyle.axaml" />
    </Application.Styles>
</Application>