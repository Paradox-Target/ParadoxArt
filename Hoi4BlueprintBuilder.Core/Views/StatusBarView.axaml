<UserControl
    x:Class="Hoi4BlueprintBuilder.Core.Views.StatusBarView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="using:Hoi4BlueprintBuilder.Core.ViewsModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vms:StatusBarViewModel"
    mc:Ignorable="d">
    <Grid ColumnDefinitions="*,Auto">
        <StackPanel
            Grid.Column="0"
            Orientation="Horizontal"
            Spacing="4">
            <TextBlock IsVisible="{Binding IsVisibleFocusCountText}" Text="{Binding FocusCountText}" />
        </StackPanel>
        <TextBlock
            Grid.Column="1"
            HorizontalAlignment="Right"
            Text="{Binding RamUsage}" />
    </Grid>
</UserControl>
