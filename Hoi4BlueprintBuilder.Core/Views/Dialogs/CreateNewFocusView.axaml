<UserControl
    x:Class="Hoi4BlueprintBuilder.Core.Views.Dialogs.CreateNewFocusView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lang="using:Hoi4BlueprintBuilder.Localization.Strings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="clr-namespace:Hoi4BlueprintBuilder.Core.ViewsModels.Dialogs"
    d:DesignHeight="300"
    d:DesignWidth="300"
    x:DataType="vms:CreateNewFocusViewModel"
    mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="StackPanel">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Spacing" Value="4" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,*,*">

        <StackPanel Grid.Row="0">
            <TextBlock Text="{x:Static lang:LangResources.CreateNewFocusView_FocusId}" />
            <TextBox VerticalAlignment="Center" Text="{Binding FocusId, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="{x:Static lang:LangResources.CreateNewFocusView_FocusType}" />
            <ComboBox ItemsSource="{Binding FocusTypes, Mode=OneTime}" SelectedIndex="{Binding SelectedFocusTypeIndex, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vms:FocusTypeItem">
                        <TextBlock Text="{Binding Path=DisplayName, Mode=OneTime}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="{x:Static lang:LangResources.CreateNewFocusView_TargetFileName}" />
            <ComboBox ItemsSource="{Binding FocusFileNames, Mode=OneTime}" SelectedIndex="{Binding SelectedFocusFileNameIndex, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vms:FocusFileItem">
                        <TextBlock Text="{Binding Path=FileName, Mode=OneTime}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
    </Grid>
</UserControl>
