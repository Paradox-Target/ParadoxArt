<UserControl
    x:Class="Hoi4BlueprintBuilder.Core.Views.ActivateView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="clr-namespace:Hoi4BlueprintBuilder.Core.ViewsModels"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    x:DataType="vms:ActivateViewModel"
    mc:Ignorable="d">

    <Grid RowDefinitions="*,*">
        <TextBox
            Grid.Row="0"
            MinWidth="300"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Text="{Binding ActivationCode, Mode=TwoWay}" />
        <Button
            Grid.Row="1"
            HorizontalAlignment="Center"
            Command="{Binding ActivateCommand}"
            Content="{Binding ButtonText, Mode=TwoWay}" />
    </Grid>
</UserControl>
