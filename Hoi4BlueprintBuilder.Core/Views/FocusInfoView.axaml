<UserControl
    x:Class="Hoi4BlueprintBuilder.Core.Views.FocusInfoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:control="using:Hoi4BlueprintBuilder.Core.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:lang="using:Hoi4BlueprintBuilder.Localization.Strings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewsModels="clr-namespace:Hoi4BlueprintBuilder.Core.ViewsModels"
    HorizontalAlignment="Right"
    VerticalAlignment="Center"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="viewsModels:FocusInfoViewModel"
    IsVisible="False"
    mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="Border.FocusConditionBorder">
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Padding">4,2</Setter>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ExpanderHeaderBorderBrush}" />
            <Setter Property="BorderThickness">1</Setter>
            <Setter Property="CornerRadius">4</Setter>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Border
            Padding="10"
            Background="{DynamicResource ThemeFocusInfoCardBackground}"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,8,0" Spacing="4">

                    <StackPanel DragDrop.AllowDrop="True">
                        <TextBlock Text="Icon" />
                        <Image
                            x:Name="FocusIcon"
                            Margin="0,0,0,8"
                            ToolTip.Tip="{Binding IconPath}" />
                        <TextBox Text="{Binding FocusNode.Icon, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="ID" />
                        <TextBox Margin="0,4,0,0" Text="{Binding FocusNode.Id, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="{x:Static lang:LangResources.FocusInfoCard_PositioningSystem}" />
                        <Border Background="#71afe5" CornerRadius="4">
                            <TextBlock Margin="4" Text="{Binding LocationSystemText, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsRelativePositionVisible}" Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Bottom" Text="{x:Static lang:LangResources.FocusInfoCard_PositionRelativeTo}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            VerticalAlignment="Top"
                            Text="{Binding RelativePositionFocusName, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="X: " />
                        <fa:FANumberBox Value="{Binding X, Mode=TwoWay}" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="Y: " />
                        <fa:FANumberBox Value="{Binding Y, Mode=TwoWay}" />
                    </StackPanel>

                    <TextBlock Text="Cost" />
                    <StackPanel Orientation="Horizontal">
                        <fa:FANumberBox
                            Minimum="0"
                            SpinButtonPlacementMode="Inline"
                            ValidationMode="InvalidInputOverwritten"
                            Value="{Binding Cost, Mode=TwoWay}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            Text="{Binding FocusDaysTip}" />
                    </StackPanel>

                    <Expander
                        DragDrop.AllowDrop="True"
                        DragDrop.Drop="AddPrerequisiteDragHandler"
                        Header="{x:Static lang:LangResources.FocusInfoCard_Prerequisites}"
                        Theme="{StaticResource ExpanderWinUIAnimationStyle}">

                        <ItemsControl x:Name="PrerequisiteItemsControl" ItemsSource="{Binding FocusNode.Prerequisite}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- 外层每项是一个 List<FocusNode>，用 Border 包裹 -->
                                    <Border
                                        Padding="8"
                                        Classes="FocusConditionBorder"
                                        DragDrop.AllowDrop="True"
                                        DragDrop.Drop="AddPrerequisiteDragHandler">

                                        <!--  设置 Background 是为了整个 Border 都能响应 DragDrop  -->
                                        <StackPanel Background="Transparent">
                                            <StackPanel
                                                Margin="0,0,0,8"
                                                Orientation="Horizontal"
                                                Spacing="4">
                                                <fa:FAFontIcon
                                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                    FontSize="12"
                                                    Glyph="&#xE71D;" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="12"
                                                    Text="{x:Static lang:LangResources.FocusInfoCard_PrerequisitesTip}" />
                                            </StackPanel>

                                            <!-- 内层 ItemsControl 显示 List<FocusNode> 中的元素 -->
                                            <!-- ItemsSource="{Binding}" 指向当前的 List<FocusNode> -->
                                            <ItemsControl ItemsSource="{Binding}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!--  这里显示单个 FocusNode  -->
                                                        <Border Classes="FocusConditionBorder" ToolTip.Tip="{Binding Id}">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock
                                                                    VerticalAlignment="Center"
                                                                    FontSize="12"
                                                                    Text="{Binding LocalizedName}" />
                                                                <Button Click="RemovePrerequisite">
                                                                    <Button.Content>
                                                                        <fa:FASymbolIcon Symbol="Cancel" />
                                                                    </Button.Content>
                                                                </Button>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander
                        DragDrop.AllowDrop="True"
                        DragDrop.Drop="AddMutuallyExclusiveDragHandler"
                        Header="{x:Static lang:LangResources.FocusInfoCard_MutualExclusion}"
                        Theme="{StaticResource ExpanderWinUIAnimationStyle}">
                        <ItemsControl ItemsSource="{Binding FocusNode.MutuallyExclusive}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="FocusConditionBorder" ToolTip.Tip="{Binding Id}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Text="{Binding LocalizedName}" />
                                            <Button Click="RemoveMutuallyExclusive">
                                                <Button.Content>
                                                    <fa:FASymbolIcon Symbol="Cancel" />
                                                </Button.Content>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <!--  cancel_if_invalid  -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock
                            VerticalAlignment="Center"
                            Classes="BodyTextBlock"
                            Text="{x:Static lang:LangResources.FocusInfoCard_CancelIfInvalid}" />
                        <ToggleSwitch
                            VerticalAlignment="Center"
                            Classes="CleanToggleSwitch"
                            IsChecked="{Binding FocusNode.CancelIfInvalid, Mode=TwoWay}" />
                    </StackPanel>

                    <!--  continue_if_invalid  -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock
                            VerticalAlignment="Center"
                            Classes="BodyTextBlock"
                            Text="{x:Static lang:LangResources.FocusInfoCard_ContinueIfInvalid}" />
                        <ToggleSwitch
                            VerticalAlignment="Center"
                            Classes="CleanToggleSwitch"
                            IsChecked="{Binding FocusNode.ContinueIfInvalid, Mode=TwoWay}" />
                    </StackPanel>

                    <Expander Header="{x:Static lang:LangResources.CompletionEffect}">
                        <Border
                            Margin="0,4,0,0"
                            BorderBrush="Gray"
                            BorderThickness="0,0,0,1"
                            CornerRadius="4">
                            <control:TextEditorControl
                                x:Name="CompletionRewardEditor"
                                MinHeight="100"
                                Padding="4,0,0,18"
                                Background="Transparent"
                                FontFamily="Cascadia Code"
                                FontSize="12" />
                        </Border>
                    </Expander>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="22"
                            Text="{x:Static lang:LangResources.Localization}" />
                        <ComboBox
                            Margin="8,0,0,0"
                            ItemsSource="{Binding Languages, Mode=OneTime}"
                            SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Text" />
                        <TextBox Margin="0,4,0,0" Text="{Binding IdText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="{x:Static lang:LangResources.Description}" />

                        <TextBox
                            Margin="0,8,0,0"
                            VerticalAlignment="Top"
                            AcceptsReturn="True"
                            Text="{Binding DescriptionText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!--  左侧调整边，使用负Margin将其向外移动一点，或直接覆盖边缘  -->
        <Thumb
            Width="6"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Cursor="SizeWestEast"
            DragDelta="ResizeThumbLeft_OnDragDelta">
            <Thumb.Template>
                <ControlTemplate>
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!--  底部调整边  -->
        <Thumb
            Height="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Cursor="SizeNorthSouth"
            DragDelta="ResizeThumbBottom_OnDragDelta">
            <Thumb.Template>
                <ControlTemplate>
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!--  左下角调整  -->
        <Thumb
            Width="8"
            Height="8"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Cursor="BottomLeftCorner"
            DragDelta="ResizeThumbBottomLeft_OnDragDelta">
            <Thumb.Template>
                <ControlTemplate>
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</UserControl>