<UserControl
    x:Class="Hoi4BlueprintBuilder.Core.Views.LoadingView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="using:FluentAvalonia.UI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="{StaticResource MainWindowWidth}"
    d:DesignWidth="{StaticResource MainWindowHeight}"
    mc:Ignorable="d">
    <Grid RowDefinitions="*,*">

        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            FontSize="25"
            Text="正在检查设备授权..." />
        <fa:ProgressRing
            Grid.Row="1"
            Width="80"
            Height="80"
            IsActive="True" />
    </Grid>
</UserControl>
