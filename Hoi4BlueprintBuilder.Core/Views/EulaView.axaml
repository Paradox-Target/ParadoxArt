<UserControl
    x:Class="Hoi4BlueprintBuilder.Core.Views.EulaView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Styles>
        <Style Selector="Border.EulaCard">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BoxShadow" Value="0 12 36 0 #18000000" />
        </Style>

        <Style Selector="Button.EulaActionButton">
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Height" Value="38" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <Grid
        Margin="16,10,16,16"
        RowDefinitions="*"
        Background="{DynamicResource LayerFillColorAltBrush}">
        <Border
            MaxWidth="940"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            Classes="EulaCard">
            <Grid RowDefinitions="Auto,*,Auto">
                <Border
                    Padding="22,18,22,16"
                    Background="{DynamicResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="TitleTextBlock" Text="用户协议" />
                        <TextBlock
                            Classes="BodyTextBlock"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="请完整阅读协议内容。继续使用本应用即表示您理解并同意相关条款。" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Margin="16,14,16,14"
                    Padding="2"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <ScrollViewer>
                        <md:MarkdownRenderer x:Name="MarkdownRenderer" Margin="18,14" />
                    </ScrollViewer>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="16,12"
                    Background="{DynamicResource LayerFillColorAltBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBlock
                            VerticalAlignment="Center"
                            Classes="BodyStrongTextBlock"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="建议在继续前确认您已阅读全部条款" />

                        <Button
                            Grid.Column="1"
                            Classes="EulaActionButton"
                            Click="ExitApp"
                            Content="拒绝并退出" />

                        <Button
                            Grid.Column="2"
                            Classes="EulaActionButton accent"
                            Click="NextStep"
                            Content="同意并继续" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
