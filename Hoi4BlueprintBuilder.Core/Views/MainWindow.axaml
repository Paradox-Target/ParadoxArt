<fa:AppWindow
    x:Class="Hoi4BlueprintBuilder.Core.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Hoi4BlueprintBuilder.Core.Views"
    xmlns:vms="using:Hoi4BlueprintBuilder.Core.ViewsModels"
    xmlns:fa="using:FluentAvalonia.UI.Windowing"
    Title="Hoi4BlueprintBuilder"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vms:MainWindowViewModel"
    Icon="/Assets/logo.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    
    <Grid RowDefinitions="Auto,*">
        <StackPanel Margin="0,0,0,4" Spacing="4" Grid.Row="0" Orientation="Horizontal">
            <Image Width="32" Height="32" Source="../Assets/logo.ico" />
            <TextBlock Text="Hoi4BlueprintBuilder"/>
        </StackPanel>
        <ContentControl Grid.Row="1" x:Name="MainContent" Content="{Binding CurrentView, Mode=OneWay}" />
    </Grid>
    
</fa:AppWindow>
