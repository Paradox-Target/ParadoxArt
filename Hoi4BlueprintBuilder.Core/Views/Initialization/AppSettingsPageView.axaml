<UserControl
    x:Class="Hoi4BlueprintBuilder.Core.Views.Initialization.AppSettingsPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lang="using:Hoi4BlueprintBuilder.Localization.Strings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Hoi4BlueprintBuilder.Core.Models"
    xmlns:vms="clr-namespace:Hoi4BlueprintBuilder.Core.ViewsModels.Initialization"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vms:AppSettingsPageViewModel"
    mc:Ignorable="d">
    <Grid
        VerticalAlignment="Center"
        ColumnDefinitions="*,*,*"
        RowDefinitions="*,*,*,*">

        <StackPanel
            Grid.RowSpan="3"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <Image Classes="SettingsIconImage" Source="{StaticResource AppSettingsMainIcon}" />
        </StackPanel>

        <StackPanel
            Grid.Row="0"
            Grid.RowSpan="3"
            Grid.Column="1"
            Grid.ColumnSpan="2"
            Margin="20">
            <StackPanel Margin="0,16">
                <TextBlock Classes="SettingsTitleTextBlock" Text="语言(Language)" />
                <ComboBox
                    Classes="SettingsPickComboboxStyle"
                    ItemsSource="{Binding Languages, Mode=OneTime}"
                    SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:LanguageInfo">
                            <TextBlock Text="{Binding DisplayName, Mode=OneTime}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel>
                <TextBlock Classes="SettingsTitleTextBlock" Text="游戏语言(Game Language)" />
                <ComboBox
                    Classes="SettingsPickComboboxStyle"
                    ItemsSource="{Binding GameLanguages, Mode=OneTime}"
                    SelectedIndex="{Binding SelectedGameLanguageIndex, Mode=TwoWay}" />
            </StackPanel>
        </StackPanel>

        <StackPanel
            Grid.Row="3"
            Grid.Column="1"
            Margin="0,28"
            HorizontalAlignment="Center">
            <Button
                HorizontalAlignment="Right"
                Classes="SettingsStepButton"
                Click="Previous_OnClick"
                Content="{x:Static lang:LangResources.Initialization_Previous}" />
        </StackPanel>
        <StackPanel
            Grid.Row="3"
            Grid.Column="2"
            Margin="0,28"
            HorizontalAlignment="Center">
            <Button
                HorizontalAlignment="Right"
                Classes="SettingsStepButton accent"
                Click="Next_OnClick"
                Content="完成" />
        </StackPanel>
    </Grid>
</UserControl>