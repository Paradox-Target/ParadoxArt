<controls:UserControl
    d:DesignHeight="{StaticResource MainWindowHeight}"
    d:DesignWidth="{StaticResource MainWindowWidth}"
    mc:Ignorable="d"
    x:Class="Hoi4BlueprintBuilder.Core.Views.Initialization.MainWelcomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:controls="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Frame Name="MainFrame" NavigationUIVisibility="Hidden" />
</controls:UserControl>