<UserControl
    x:Class="Hoi4BlueprintBuilder.Core.Views.FocusIconPickerView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Hoi4BlueprintBuilder.Core.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:Hoi4BlueprintBuilder.Core.Models.Focus"
    xmlns:vms="using:Hoi4BlueprintBuilder.Core.ViewsModels"
    x:Name="MainControl"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vms:FocusIconPickerViewModel"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
            <TextBlock
                Grid.Column="0"
                Margin="8,0"
                VerticalAlignment="Center"
                Classes="BodyStrongTextBlock"
                Text="{Binding Sum}" />
            <TextBox
                Grid.Column="1"
                PlaceholderText="Search..."
                Text="{Binding SearchText.Value}">
                <TextBox.InnerLeftContent>
                    <controls:FontIcon
                        Margin="12,0,8,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE721;" />
                </TextBox.InnerLeftContent>
            </TextBox>
        </Grid>

        <ItemsRepeater Grid.Row="1" ItemsSource="{Binding FocusIcons}">
            <ItemsRepeater.Layout>
                <UniformGridLayout
                    MinColumnSpacing="4"
                    MinItemHeight="88"
                    MinItemWidth="100"
                    MinRowSpacing="4" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="model:FocusIcon">
                    <ToggleButton
                        x:Name="PickButton"
                        Command="{Binding Path=((vms:FocusIconPickerViewModel)DataContext).PickFocusIconCommand, ElementName=MainControl}"
                        CommandParameter="{Binding ElementName=PickButton}">
                        <Image
                            Source="{Binding Icon}"
                            Stretch="Uniform"
                            ToolTip.Tip="{Binding Name}" />
                    </ToggleButton>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
    </Grid>
</UserControl>
