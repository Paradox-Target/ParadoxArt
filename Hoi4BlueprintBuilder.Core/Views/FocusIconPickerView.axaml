<fa:FAAppWindow
    x:Class="Hoi4BlueprintBuilder.Core.Views.FocusIconPickerView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Hoi4BlueprintBuilder.Core.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="using:FluentAvalonia.UI.Windowing"
    xmlns:lang="using:Hoi4BlueprintBuilder.Localization.Strings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:Hoi4BlueprintBuilder.Core.Models.Focus"
    xmlns:vms="using:Hoi4BlueprintBuilder.Core.ViewsModels"
    x:Name="MainControl"
    Title="{x:Static lang:LangResources.FocusIconPickerView_Title}"
    Width="800"
    Height="550"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vms:FocusIconPickerViewModel"
    WindowDecorations="BorderOnly"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid Margin="8" RowDefinitions="*,Auto">
        <Grid Grid.Row="0" RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                <TextBlock
                    Grid.Column="0"
                    Margin="8,0"
                    VerticalAlignment="Center"
                    Classes="BodyStrongTextBlock"
                    Text="{Binding Sum}" />
                <TextBox
                    Grid.Column="1"
                    PlaceholderText="Search..."
                    Text="{Binding SearchText.Value}">
                    <TextBox.InnerLeftContent>
                        <controls:FontIcon
                            Margin="12,0,8,0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE721;" />
                    </TextBox.InnerLeftContent>
                </TextBox>
            </Grid>
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                <ItemsRepeater ItemsSource="{Binding FocusIcons}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinColumnSpacing="4"
                            MinItemHeight="88"
                            MinItemWidth="100"
                            MinRowSpacing="4" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="model:FocusIcon">
                            <ToggleButton
                                x:Name="PickButton"
                                Command="{Binding Path=((vms:FocusIconPickerViewModel)DataContext).PickFocusIconCommand, ElementName=MainControl}"
                                CommandParameter="{Binding ElementName=PickButton}">
                                <Image
                                    Source="{Binding Icon}"
                                    Stretch="Uniform"
                                    ToolTip.Tip="{Binding Name}" />
                            </ToggleButton>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>

        <StackPanel
            Grid.Row="1"
            Margin="8"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding CancelCommand}" Content="{x:Static lang:LangResources.Common_Cancel}" />
            <Button
                Command="{Binding OkCommand}"
                Content="{x:Static lang:LangResources.Common_Ok}"
                IsDefault="True" />
        </StackPanel>
    </Grid>
</fa:FAAppWindow>
