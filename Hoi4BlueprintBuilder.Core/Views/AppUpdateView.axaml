<UserControl
    x:Class="Hoi4BlueprintBuilder.Core.Views.AppUpdateView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Hoi4BlueprintBuilder.Core.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="using:FluentAvalonia.UI.Controls"
    xmlns:lang="using:Hoi4BlueprintBuilder.Localization.Strings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
    xmlns:vms="clr-namespace:Hoi4BlueprintBuilder.Core.ViewsModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vms:AppUpdateViewModel"
    mc:Ignorable="d">

    <Panel>
        <!--  检查更新状态  -->
        <Grid
            Background="{DynamicResource LayerFillColorDefaultBrush}"
            IsVisible="{Binding !HasUpdates}"
            RowDefinitions="*,*">
            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Spacing="16">
                <controls:FontIcon
                    HorizontalAlignment="Center"
                    FontSize="48"
                    Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                    Glyph="&#xE896;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{x:Static lang:LangResources.AppUpdate_Checking}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{x:Static lang:LangResources.AppUpdate_CheckWaitDetails}" />
            </StackPanel>
            <fa:FAProgressRing
                Grid.Row="1"
                Width="48"
                Height="48"
                VerticalAlignment="Top"
                Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                IsActive="True" />
        </Grid>

        <!--  更新日志视图  -->
        <Border
            Margin="16"
            Padding="0"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            IsVisible="{Binding ShowUpdateLog}">
            <Grid RowDefinitions="Auto,*,Auto">
                <!--  头部  -->
                <Border
                    Grid.Row="0"
                    Padding="16,16,16,12"
                    Background="{DynamicResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="20"
                                FontWeight="Bold"
                                Text="{x:Static lang:LangResources.AppUpdate_NewVersionAvailable}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{x:Static lang:LangResources.AppUpdate_RecommendUpdate}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="6">
                            <Border
                                Padding="8,4"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="4">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                    Text="{Binding NewVersionText}" />
                            </Border>
                            <Border
                                Padding="8,2"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                CornerRadius="4">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                    Text="{Binding AppUpdateChannelText, Mode=OneTime}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  滚动日志  -->
                <ScrollViewer Grid.Row="1" Padding="20,16">
                    <md:MarkdownRenderer
                        x:Name="MarkdownRenderer"
                        LinkCommand="{Binding OpenLinkCommand}"
                        MarkdownBuilder="{Binding UpdateLog}" />
                </ScrollViewer>

                <!--  底部操作栏  -->
                <Border
                    Grid.Row="2"
                    Padding="16,12"
                    Background="{DynamicResource LayerFillColorAltBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding TotalPackagesSize}" />
                        <Button
                            Grid.Column="1"
                            Width="120"
                            Height="36"
                            Classes="accent"
                            Command="{Binding StartUpdateAppCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <controls:FontIcon FontSize="16" Glyph="&#xE896;" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="{x:Static lang:LangResources.AppUpdate_StartUpdate}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!--  下载进度视图  -->
        <Border
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource LayerFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            BoxShadow="0 8 32 0 #1A000000"
            CornerRadius="12"
            IsVisible="{Binding IsDownloading}">
            <StackPanel Width="320" Spacing="16">
                <controls:FontIcon
                    HorizontalAlignment="Center"
                    FontSize="40"
                    Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                    Glyph="&#xE896;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Static lang:LangResources.AppUpdate_Downloading}" />

                <ProgressBar
                    Height="6"
                    Margin="0,8"
                    Value="{Binding Progress}" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{x:Static lang:LangResources.AppUpdate_DownloadProgress}" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Text="{Binding ProgressText, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </Border>
    </Panel>
</UserControl>
